{
	"name": "pigeon-app",
	"private": true,
	"version": "1.8.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"tauri": "tauri",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . --ext .js,.ts,.svelte --ignore-path .gitignore",
		"lint:fix": "eslint . --ext .js,.ts,.svelte --fix --ignore-path .gitignore",
		"test": "vitest",
		"test:run": "vitest run",
		"build:tauri": "cross-env TAURI_BUILD=true npm run build",
		"android:init": "tauri android init",
		"android:dev": "tauri android dev",
		"android:build": "cross-env TAURI_BUILD=true tauri android build --apk"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@tauri-apps/cli": "^2.0.0-rc.18",
		"@types/node": "^24.5.2",
		"@typescript-eslint/eslint-plugin": "^6.0.0",
		"@typescript-eslint/parser": "^6.0.0",
		"cross-env": "^10.1.0",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^2.36.1",
		"sass-embedded": "^1.100.0",
		"svelte": "^4.0.0",
		"svelte-check": "^3.8.6",
		"typescript": "^5.0.0",
		"vite": "^5.0.3",
		"vitest": "^2.0.0"
	},
	"dependencies": {
		"@codemirror/lang-markdown": "^6.5.1",
		"@codemirror/state": "^6.7.1",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.43.6",
		"@lezer/markdown": "^1.7.2",
		"@tanstack/svelte-query": "^5.0.0",
		"@tauri-apps/api": "^2.8.0",
		"@tauri-apps/plugin-fs": "^2.0.0-rc",
		"@types/hast": "^3.0.5",
		"@types/highlight.js": "^9.12.4",
		"@types/markdown-it": "^14.1.2",
		"codemirror-markdown-hybrid": "^1.2.2",
		"highlight.js": "^11.11.1",
		"katex": "^0.18.1",
		"lucide-svelte": "^0.575.0",
		"markdown-it": "^14.1.1",
		"rehype-katex": "^7.0.1",
		"rehype-raw": "^7.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"svelte-i18n": "^4.0.1",
		"unified": "^11.0.5"
	}
}
